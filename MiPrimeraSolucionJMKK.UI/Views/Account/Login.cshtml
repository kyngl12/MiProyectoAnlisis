@using MiPrimeraSolucion.UI.Models
@model LoginViewModel
@{
    ViewBag.Title = "Iniciar sesión";
}

<main class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0 rounded-4" style="width: 420px;">
        <div class="text-center p-3">
            <h2 id="title" class="fw-bold text-primary">Iniciar sesión</h2>
        </div>
        <div class="card-body p-4">

            @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold text-primary" })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control shadow-sm rounded-3", placeholder = "Correo electrónico" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label fw-semibold text-primary" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control shadow-sm rounded-3", placeholder = "Contraseña" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mb-3 d-flex align-items-center">
                    @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input me-2" })
                    @Html.LabelFor(m => m.RememberMe, new { @class = "form-check-label" })
                </div>

                <div class="d-flex justify-content-center mt-4">
                    <input type="submit" value="Iniciar sesión"
                           class="btn btn-primary btn-lg rounded-3 shadow-sm fw-semibold"
                           style="background: linear-gradient(90deg, #1565c0, #0d47a1); border: none; transition: all 0.3s ease;"
                           onmouseover="this.style.transform='scale(1.05)';"
                           onmouseout="this.style.transform='scale(1)';" />
                </div>

                <div class="text-center mt-3">
                    @Html.ActionLink("Registrarse como usuario nuevo", "Register", null, new { @class = "text-decoration-none fw-semibold text-primary" })
                </div>
            }
        </div>
    </div>
</main>


@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}