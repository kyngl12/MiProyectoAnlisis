@using MiPrimeraSolucion.UI.Models
@model LoginViewModel

@{
    ViewBag.Title = "Iniciar sesión";
}

<main class="d-flex justify-content-center align-items-center vh-100">

    <div class="card shadow-lg p-4 login-card">

        <div class="text-center mb-4">

            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRNeCydP6t55kpMgzA9Fqq_a7LFUIkLcTUeOQ&s"
                 alt="Logo PubRock"
                 class="img-fluid mb-3"
                 style="max-width:120px;" />

            <h2 class="fw-bold mt-3">
                PubRock
            </h2>

            @if (TempData["MensajeError"] != null)
            {
                <div class="alert alert-danger mt-3">@TempData["MensajeError"]</div>
            }

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success mt-3">@TempData["MensajeExito"]</div>
            }

            <p class="text-muted">
                Sistema de Gestión Administrativa y Operativa
            </p>

        </div>

        @using (Html.BeginForm(
            "Login",
            "Account",
            new { ReturnUrl = ViewBag.ReturnUrl },
            FormMethod.Post,
            new { role = "form" }))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="form-group mb-3">

                @Html.LabelFor(
                    m => m.Email,
                    new { @class = "form-label" })

                @Html.TextBoxFor(
                    m => m.Email,
                    new
                    {
                        @class = "form-control",
                        placeholder = "Correo electrónico"
                    })

                @Html.ValidationMessageFor(
                    m => m.Email,
                    "",
                    new { @class = "text-danger" })

            </div>

            <div class="form-group mb-3">

                @Html.LabelFor(
                    m => m.Password,
                    new { @class = "form-label" })

                @Html.PasswordFor(
                    m => m.Password,
                    new
                    {
                        @class = "form-control",
                        placeholder = "Contraseña"
                    })

                @Html.ValidationMessageFor(
                    m => m.Password,
                    "",
                    new { @class = "text-danger" })

            </div>

            <div class="form-group mb-3 d-flex align-items-center">

                @Html.CheckBoxFor(
                    m => m.RememberMe,
                    new { @class = "form-check-input me-2" })

                @Html.LabelFor(
                    m => m.RememberMe,
                    new { @class = "form-check-label" })

            </div>

            <div class="d-grid">

                <input type="submit"
                       value="Iniciar sesión"
                       class="btn btn-pubrock btn-lg" />

            </div>

            <div class="text-center mt-3">

                @Html.ActionLink(
                    "¿Olvidó su contraseña?",
                    "ForgotPassword",
                    "Account",
                    null,
                    new
                    {
                        @class = "text-decoration-none fw-semibold link-acento"
                    })

            </div>

            <div class="text-center mt-4">

                @Html.ActionLink(
                    "Registrarse como usuario nuevo",
                    "Register",
                    null,
                    new
                    {
                        @class = "text-decoration-none fw-semibold link-acento"
                    })

            </div>
        }

    </div>

</main>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}