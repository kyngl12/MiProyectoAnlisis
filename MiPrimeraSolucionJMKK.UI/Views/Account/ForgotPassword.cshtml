@model MiPrimeraSolucion.UI.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "¿Olvidó su contraseña?";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <h2 class="mb-2">
                        <i class="bi bi-envelope-lock me-2"></i>
                        Recuperar Contraseña
                    </h2>

                    <p class="text-muted mb-4">
                        Especifique su correo electrónico para recibir el enlace de recuperación.
                    </p>

                    @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form" }))
                    {
                        @Html.AntiForgeryToken()

                        @Html.ValidationSummary("", new { @class = "text-danger small mb-3" })

                        <div class="mb-4">
                            @Html.LabelFor(m => m.Email, new { @class = "form-label" })

                            @Html.TextBoxFor(
                                m => m.Email,
                                new
                                {
                                    @class = "form-control",
                                    placeholder = "Ej: usuario@pubrock.com"
                                }
                            )
                        </div>

                        <div class="d-flex justify-content-end">
                            <input type="submit"
                                   class="btn btn-pubrock"
                                   value="Enviar Enlace" />
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
