@model MiPrimeraSolucion.UI.Models.RegisterViewModel

@{
    ViewBag.Title = "Registrarse";
}

<main class="d-flex justify-content-center align-items-center vh-100">

    ```
    <div class="card shadow-lg p-4 login-card">

        <div class="text-center mb-4">

            <i class="bi bi-person-plus fs-1"></i>

            <h2 class="fw-bold mt-3">
                Registrar Usuario
            </h2>

            <p class="text-muted">
                Crear una nueva cuenta
            </p>

        </div>

        @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form" }))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary("", new { @class = "text-danger mb-3" })

            <div class="form-group mb-3">

                @Html.LabelFor(
                    m => m.Email,
                    new { @class = "form-label" })

                @Html.TextBoxFor(
                    m => m.Email,
                    new
                    {
                        @class = "form-control",
                        placeholder = "Correo electrónico"
                    })

            </div>

            <div class="form-group mb-3">

                @Html.LabelFor(
                    m => m.Password,
                    new { @class = "form-label" })

                @Html.PasswordFor(
                    m => m.Password,
                    new
                    {
                        @class = "form-control",
                        placeholder = "Contraseña"
                    })

            </div>

            <div class="form-group mb-3">

                @Html.LabelFor(
                    m => m.ConfirmPassword,
                    new { @class = "form-label" })

                @Html.PasswordFor(
                    m => m.ConfirmPassword,
                    new
                    {
                        @class = "form-control",
                        placeholder = "Confirmar contraseña"
                    })

            </div>

            <div class="form-group mb-4">

                @Html.LabelFor(
                    m => m.Rol,
                    new { @class = "form-label d-block" })

                <div class="form-check form-check-inline">

                    @Html.RadioButtonFor(
                        m => m.Rol,
                        "Administrador",
                        new { @class = "form-check-input" })

                    <label class="form-check-label">
                        Administrador
                    </label>

                </div>

                <div class="form-check form-check-inline">

                    @Html.RadioButtonFor(
                        m => m.Rol,
                        "Empleado",
                        new { @class = "form-check-input" })

                    <label class="form-check-label">
                        Empleado
                    </label>

                </div>

                @Html.ValidationMessageFor(
                    m => m.Rol,
                    "",
                    new { @class = "text-danger d-block mt-1" })

            </div>

            <div class="d-grid">

                <input type="submit"
                       value="Registrarse"
                       class="btn btn-pubrock btn-lg" />

            </div>

            <div class="text-center mt-4">

                @Html.ActionLink(
                    "Volver al inicio de sesión",
                    "Login",
                    null,
                    new
                    {
                        @class = "text-decoration-none fw-semibold link-acento"
                    })

            </div>
        }

    </div>
    ```

</main>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

