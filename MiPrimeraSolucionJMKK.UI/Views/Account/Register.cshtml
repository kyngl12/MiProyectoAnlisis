@model MiPrimeraSolucion.UI.Models.RegisterViewModel
@{
    ViewBag.Title = "Registrarse";
}

<main class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0 rounded-4" style="width: 420px;">
        <div class="text-center p-3">
            <h2 id="title" class="fw-bold text-primary">Registrar</h2>
        </div>
        <div class="card-body p-4">

            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary("", new { @class = "text-danger mb-3" })

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold text-primary" })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control shadow-sm rounded-3", placeholder = "Correo electrónico" })
                </div>

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label fw-semibold text-primary" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control shadow-sm rounded-3", placeholder = "Contraseña" })
                </div>

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label fw-semibold text-primary" })
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control shadow-sm rounded-3", placeholder = "Confirmar contraseña" })
                </div>

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.Rol, new { @class = "form-label fw-semibold text-primary d-block" })
                    <div class="form-check form-check-inline">
                        @Html.RadioButtonFor(m => m.Rol, "Administrador", new { @class = "form-check-input" })
                        <label class="form-check-label">Administrador</label>
                    </div>
                    <div class="form-check form-check-inline">
                        @Html.RadioButtonFor(m => m.Rol, "Cajero", new { @class = "form-check-input" })
                        <label class="form-check-label">Cajero</label>
                    </div>
                    @Html.ValidationMessageFor(m => m.Rol, "", new { @class = "text-danger d-block mt-1" })
                </div>

                <div class="d-flex justify-content-center mt-4">
                    <input type="submit" value="Registrarse"
                           class="btn btn-primary btn-lg rounded-3 shadow-sm fw-semibold"
                           style="background: linear-gradient(90deg, #1565c0, #0d47a1); border: none; transition: all 0.3s ease;"
                           onmouseover="this.style.transform='scale(1.05)';"
                           onmouseout="this.style.transform='scale(1)';" />
                </div>
            }
        </div>
    </div>
</main>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
