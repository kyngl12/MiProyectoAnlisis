@model MiPrimeraSolucion.UI.Models.ResetPasswordViewModel
@{
    ViewBag.Title = "Restablecer Contraseña";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <h2 class="mb-2"><i class="bi bi-shield-lock me-2"></i>Restablecer Contraseña</h2>
                    <p class="text-muted mb-4">Ingrese su correo y la nueva contraseña.</p>

                    @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { role = "form" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary("", new { @class = "text-danger small mb-3" })
                        @Html.HiddenFor(model => model.Code)

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Ej: usuario@pubrock.com" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Nueva contraseña" })
                        </div>

                        <div class="mb-4">
                            @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label" })
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Confirme la contraseña" })
                        </div>

                        <div class="d-flex justify-content-end">
                            <input type="submit" class="btn btn-pubrock" value="Restablecer Contraseña" />
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
