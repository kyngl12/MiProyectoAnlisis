@model IEnumerable<MiPrimeraSolucionJMKK.Abstracciones.Modelos.Usuarios.UsuarioDto>

@{
    ViewBag.Title = "Todos los Usuarios";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Todos los Usuarios</h2>
        @Html.ActionLink(
            "Agregar Usuario",
            "AgregarUsuario",
            null,
            new { @class = "btn btn-primary btn-lg rounded-pill shadow-sm" }
        )
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nombres</th>
                        <th>Primer Apellido</th>
                        <th>Segundo Apellido</th>
                        <th>Identificacion</th>
                        <th>Correo Electronico</th>
                        <th>Fecha de Registro</th>
                        <th>Fecha de Modificacion</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombres</td>
                            <td>@item.PrimerApellido</td>
                            <td>@item.SegundoApellido</td>
                            <td>@item.Identificacion</td>
                            <td>@item.CorreoElectronico</td>
                            <td>@item.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.FechaDeModificacion.HasValue)
                                {
                                    @item.FechaDeModificacion.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    @Html.ActionLink("Editar", "EditarUsuario", "Usuarios", new { id = item.IdUsuario }, new { @class = "btn btn-sm btn-outline-primary" })
                                    @Html.ActionLink("Detalles", "DetallesDelUsuario", "Usuarios", new { id = item.IdUsuario }, new { @class = "btn btn-sm btn-outline-info" })
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
