@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.Usuarios.UsuarioDto

@{
    ViewBag.Title = "Agregar Usuario";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <h2 class="mb-4"><i class="bi bi-person-plus-fill me-2"></i>Agregar Nuevo Usuario</h2>

                    @if (TempData["MensajeError"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["MensajeError"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @using (Html.BeginForm("AgregarUsuario", "Usuarios", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Cedula, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.Cedula, new { @class = "form-control", placeholder = "Ej: 112340567" })
                            @Html.ValidationMessageFor(m => m.Cedula, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Ej: Juan" })
                            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger small" })
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                @Html.LabelFor(m => m.ApellidoPaterno, "Primer Apellido", new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.ApellidoPaterno, new { @class = "form-control", placeholder = "Ej: Pérez" })
                                @Html.ValidationMessageFor(m => m.ApellidoPaterno, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(m => m.ApellidoMaterno, "Segundo Apellido", new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.ApellidoMaterno, new { @class = "form-control", placeholder = "Ej: García" })
                                @Html.ValidationMessageFor(m => m.ApellidoMaterno, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.CorreoElectronico, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.CorreoElectronico, new { @class = "form-control", placeholder = "Ej: usuario@ejemplo.com", type = "email" })
                            @Html.ValidationMessageFor(m => m.CorreoElectronico, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Contrasenia, new { @class = "form-label" })
                            @Html.PasswordFor(m => m.Contrasenia, new { @class = "form-control", placeholder = "Mínimo 6 caracteres" })
                            @Html.ValidationMessageFor(m => m.Contrasenia, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Telefono, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", placeholder = "Ej: 88887777" })
                            @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger small" })
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                @Html.LabelFor(m => m.IdTipoUsuario, new { @class = "form-label" })
                                @Html.DropDownListFor(
                                    m => m.IdTipoUsuario,
                                    ViewBag.TiposDeUsuario as SelectList,
                                    "-- Seleccione un rol --",
                                    new { @class = "form-select" }
                                )
                                @Html.ValidationMessageFor(m => m.IdTipoUsuario, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(m => m.IdEstado, new { @class = "form-label" })
                                @Html.DropDownListFor(
                                    m => m.IdEstado,
                                    new SelectList(
                                        new[]
                                        {
                                            new { Value = 1, Text = "Activo" },
                                            new { Value = 2, Text = "Inactivo" }
                                        },
                                        "Value",
                                        "Text"
                                    ),
                                    "-- Seleccione --",
                                    new { @class = "form-select" }
                                )
                                @Html.ValidationMessageFor(m => m.IdEstado, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            @Html.ActionLink("Cancelar", "ObtenerTodosLosUsuarios", null, new { @class = "btn btn-secondary" })

                            <button type="submit" class="btn btn-pubrock">
                                <i class="bi bi-person-check-fill me-1"></i>Guardar Usuario
                            </button>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>
