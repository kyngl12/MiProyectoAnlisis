@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.Usuarios.UsuarioDto

@{
    ViewBag.Title = "Editar Usuario";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-warning text-dark rounded-top-4">
                    <h4 class="mb-0">Editar Usuario</h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-warning alert-dismissible fade show" role="alert">
                            @TempData["Mensaje"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @using (Html.BeginForm("EditarUsuario", "Usuarios", FormMethod.Post, new { @class = "needs-validation" }))
                    {
                        @Html.AntiForgeryToken()

                        @Html.HiddenFor(model => model.IdUsuario)
                        @Html.HiddenFor(model => model.IdComercio)
                        @Html.HiddenFor(model => model.FechaDeRegistro)
                        @Html.HiddenFor(model => model.IdNetUser)

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombres</label>
                            @Html.TextBoxFor(model => model.Nombres, new { @class = "form-control", @placeholder = "Ej: Juan", @required = "required" })
                            @Html.ValidationMessageFor(model => model.Nombres, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Primer Apellido</label>
                            @Html.TextBoxFor(model => model.PrimerApellido, new { @class = "form-control", @placeholder = "Ej: Pérez", @required = "required" })
                            @Html.ValidationMessageFor(model => model.PrimerApellido, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Segundo Apellido</label>
                            @Html.TextBoxFor(model => model.SegundoApellido, new { @class = "form-control", @placeholder = "Ej: García", @required = "required" })
                            @Html.ValidationMessageFor(model => model.SegundoApellido, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Identificación</label>
                            @Html.TextBoxFor(model => model.Identificacion, new { @class = "form-control", @placeholder = "Ej: 1234567", @required = "required" })
                            @Html.ValidationMessageFor(model => model.Identificacion, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo Electrónico</label>
                            @Html.TextBoxFor(model => model.CorreoElectronico, new { @class = "form-control", @type = "email", @placeholder = "Ej: usuario@ejemplo.com", @required = "required" })
                            @Html.ValidationMessageFor(model => model.CorreoElectronico, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Estado</label>
                            <div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(model => model.Estado, true, new { @class = "form-check-input" })
                                    <label class="form-check-label">Activo</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(model => model.Estado, false, new { @class = "form-check-input" })
                                    <label class="form-check-label">Inactivo</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Fecha de Registro</label>
                            <input type="text" class="form-control" value="@Model.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")" disabled />
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            @Html.ActionLink("Cancelar", "ObtenerTodosLosUsuarios", null, new { @class = "btn btn-secondary" })
                            <button type="submit" class="btn btn-success">Actualizar Usuario</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
