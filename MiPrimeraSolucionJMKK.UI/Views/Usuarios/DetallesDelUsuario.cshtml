@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.Usuarios.UsuarioDto

@{
    ViewBag.Title = "Detalles del Usuario";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-info text-white rounded-top-4">
                    <h4 class="mb-0">Detalles del Usuario</h4>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Nombre Completo</h6>
                            <p class="fw-bold">@Model.NombreCompleto</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Identificación</h6>
                            <p class="fw-bold">@Model.Identificacion</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Correo Electrónico</h6>
                            <p class="fw-bold">@Model.CorreoElectronico</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Estado</h6>
                            <p>
                                @if (Model.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Fecha de Registro</h6>
                            <p class="fw-bold">@Model.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Fecha de Modificación</h6>
                            <p class="fw-bold">
                                @if (Model.FechaDeModificacion.HasValue)
                                {
                                    @Model.FechaDeModificacion.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        @Html.ActionLink("Volver", "ObtenerTodosLosUsuarios", null, new { @class = "btn btn-secondary" })
                        @Html.ActionLink("Editar", "EditarUsuario", "Usuarios", new { id = Model.IdUsuario }, new { @class = "btn btn-warning" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
