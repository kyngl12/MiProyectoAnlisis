@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.Comercios.ComercioDto

@{
    ViewBag.Title = "Agregar Comercio";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-white text-center py-3 rounded-top-4">
                    <h3 class="mb-0"><i class="bi bi-shop"></i> Agregar Comercio</h3>
                </div>

                <div class="card-body p-4">

                        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["MensajeError"]
                            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    }

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.IdComercio)

                        <div class="row g-3">
                            <div class="col-md-6">
                                @Html.LabelFor(model => model.Identificacion, new { @class = "form-label fw-semibold" })
                                @Html.EditorFor(model => model.Identificacion, new { htmlAttributes = new { @class = "form-control rounded-pill", placeholder = "Ej: 123456789" } })
                                @Html.ValidationMessageFor(model => model.Identificacion, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.TipoIdentificacion, new { @class = "form-label fw-semibold" })
                                @Html.EditorFor(model => model.TipoIdentificacion, new { htmlAttributes = new { @class = "form-control rounded-pill" } })
                                @Html.ValidationMessageFor(model => model.TipoIdentificacion, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.Nombre, new { @class = "form-label fw-semibold" })
                                @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control rounded-pill", placeholder = "Ej: Mi Comercio" } })
                                @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.TipoDeComercio, new { @class = "form-label fw-semibold" })
                                @Html.EditorFor(model => model.TipoDeComercio, new { htmlAttributes = new { @class = "form-control rounded-pill" } })
                                @Html.ValidationMessageFor(model => model.TipoDeComercio, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.Telefono, new { @class = "form-label fw-semibold" })
                                @Html.EditorFor(model => model.Telefono, new { htmlAttributes = new { @class = "form-control rounded-pill", placeholder = "Ej: 88881234" } })
                                @Html.ValidationMessageFor(model => model.Telefono, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.CorreoElectronico, new { @class = "form-label fw-semibold" })
                                @Html.EditorFor(model => model.CorreoElectronico, new { htmlAttributes = new { @class = "form-control rounded-pill", placeholder = "ejemplo@correo.com" } })
                                @Html.ValidationMessageFor(model => model.CorreoElectronico, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-12">
                                @Html.LabelFor(model => model.Direccion, new { @class = "form-label fw-semibold" })
                                @Html.EditorFor(model => model.Direccion, new { htmlAttributes = new { @class = "form-control rounded-pill", placeholder = "Ej: Calle 123, San José" } })
                                @Html.ValidationMessageFor(model => model.Direccion, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill shadow-sm">
                                <i class="bi bi-check-lg me-2"></i> Agregar Comercio
                            </button>
                            @Html.ActionLink(
                                "Volver",
                                "Index",
                                null,
                                new { @class = "btn btn-secondary btn-lg rounded-pill shadow-sm" }
                            )
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}