@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.Cajas.CajaDto

@{
    ViewBag.Title = "Agregar Caja";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-white text-center py-3 rounded-top-4">
                    <h3 class="mb-0"><i class="bi bi-box-seam"></i> Agregar Caja</h3>
                </div>

                <div class="card-body p-4">

                    @* Mensaje de error *@
                    @if (TempData["MensajeError"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["MensajeError"]
                            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    }

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.IdComercio)

                        <div class="mb-3 position-relative">
                            <i class="bi bi-card-text position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                            @Html.LabelFor(model => model.Nombre, "Nombre de la Caja", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control rounded-pill ps-5", placeholder = "Ej: Caja Principal" } })
                            @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3 position-relative">
                            <i class="bi bi-journal-text position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                            @Html.LabelFor(model => model.Descripcion, "Descripción", new { @class = "form-label fw-semibold" })
                            @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control rounded ps-5", rows = 3, placeholder = "Opcional: breve descripción de la caja" })
                            @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3 position-relative">
                            <i class="bi bi-telephone-fill position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                            @Html.LabelFor(model => model.TelefonoSINPE, "Teléfono SINPE", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.TelefonoSINPE, new { htmlAttributes = new { @class = "form-control rounded-pill ps-5", placeholder = "Ej: 88881234" } })
                            @Html.ValidationMessageFor(model => model.TelefonoSINPE, "", new { @class = "text-danger small" })
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill shadow-sm">
                                <i class="bi bi-check-lg me-2"></i> Agregar Caja
                            </button>
                            @Html.ActionLink(
                                "Volver",
                                "ObtenerCajasPorComercio",
                                new { idComercio = Model?.IdComercio ?? 0 },
                                new { @class = "btn btn-secondary btn-lg rounded-pill shadow-sm" }
                            )
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}