@model IEnumerable<MiPrimeraSolucionJMKK.Abstracciones.Modelos.Cajas.CajaDto>

<div class="container py-4">
    <h2 class="mb-4 text-center"><i class="bi bi-box-seam"></i> Cajas del comercio</h2>

    <div class="mb-3 text-end">
        @if (ViewBag.IdComercio != null)
        {
            @Html.ActionLink("Agregar caja", "AgregarCaja", new { idComercio = ViewBag.IdComercio },
                new { @class = "btn btn-success btn-lg rounded-pill shadow-sm" })
        }
        else
        {
            <span class="text-danger">No se puede agregar caja: idComercio no definido</span>
        }
    </div>

    <div class="table-responsive shadow-sm rounded-4">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark text-center">
                <tr>
                    <th>Nombre</th>
                    <th>Descripcion</th>
                    <th>Telefono SINPE</th>
                    <th>Fecha de registro</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nombre</td>
                        <td>@item.DescripcionCorta</td>
                        <td class="text-center">@item.TelefonoSINPE</td>
                        <td class="text-center">@item.FechaDeRegistro.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if (item.Estado)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            @Html.ActionLink("Editar", "EditarCaja", new { id = item.IdCaja },
                                new { @class = "btn btn-sm btn-warning me-1" })
                            @Html.ActionLink("Ver SINPE", "VerSINPE", new { idCaja = item.IdCaja },
                                new { @class = "btn btn-sm btn-info" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3 text-center">
        @Html.ActionLink("Volver a comercios", "ObtenerTodosLosComercios", "Comercios", null,
            new { @class = "btn btn-secondary btn-lg rounded-pill" })
    </div>
</div>