@model IEnumerable<MiPrimeraSolucionJMKK.Abstracciones.Modelos.ConfiguracionComercio.ConfiguracionComercioDto>

@{
    ViewBag.Title = "Configuración de Comercio";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Configuración de Comercio</h2>
        @if (!Model.Any())
        {
            @Html.ActionLink(
                "Agregar Configuración",
                "AgregarConfiguracion",
                new { idComercio = ViewBag.IdComercio },
                new { @class = "btn btn-primary btn-lg rounded-pill shadow-sm" }
            )
        }
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nombre del Comercio</th>
                        <th>Tipo de Configuración</th>
                        <th>Comisión (%)</th>
                        <th>Fecha de Registro</th>
                        <th>Fecha de Modificación</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.NombreComercio</td>
                                <td>
                                    @{
                                        string badgeClass = item.TipoConfiguracion switch
                                        {
                                            1 => "bg-primary",
                                            2 => "bg-warning text-dark",
                                            3 => "bg-info text-dark",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@item.TipoConfiguracionTexto</span>
                                </td>
                                <td>@item.Comision%</td>
                                <td>@item.FechaDeRegistro.ToString("dd/MM/yyyy")</td>
                                <td>@(item.FechaDeModificacion?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    @Html.ActionLink("Editar", "EditarConfiguracion", new { id = item.IdConfiguracion }, new { @class = "btn btn-sm btn-outline-primary" })
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">
                                <p class="mb-0">No hay configuración registrada para este comercio.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("Volver a Comercios", "ObtenerTodosLosComercios", "Comercios", null, new { @class = "btn btn-secondary" })
    </div>
</div>
