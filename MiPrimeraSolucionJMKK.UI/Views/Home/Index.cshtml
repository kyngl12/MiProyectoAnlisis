@{
    ViewBag.Title = "Gestión Operativa y Administrativa PubRock";
}

<div class="container py-5">
    <section class="text-center mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-primary mb-3">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRNeCydP6t55kpMgzA9Fqq_a7LFUIkLcTUeOQ&s"
                         alt="Logo"
                         style="height:70px; width:auto; margin-right:10px;" />

                    PubRock
                </h1>
                <p class="lead text-muted mb-4">
                    Plataforma de gestión operativa y administrativa para el Bar-Restaurante PubRock
                </p>
                <div class="d-flex gap-3 justify-content-center">
                    @if (Request.IsAuthenticated)
                    {
                        if (User.IsInRole("Administrador"))
                        {
                            @Html.ActionLink("Gestionar Comercios", "ObtenerTodosLosComercios", "Comercios", null, new { @class = "btn btn-primary btn-lg rounded-pill shadow" })
                            @Html.ActionLink("Ver Reportes", "ObtenerTodosLosReportesMensuales", "ReportesMensuales", null, new { @class = "btn btn-outline-primary btn-lg rounded-pill" })
                        }
                        else if (User.IsInRole("Cajero"))
                        {
                            @Html.ActionLink("Mis Cajas", "ObtenerTodasLasCajas", "Cajas", null, new { @class = "btn btn-primary btn-lg rounded-pill shadow" })
                        }
                    }
                    else
                    {
                        @Html.ActionLink("Iniciar Sesión", "Login", "Account", null, new { @class = "btn btn-primary btn-lg rounded-pill shadow" })
                        @Html.ActionLink("Registrarse", "Register", "Account", null, new { @class = "btn btn-outline-primary btn-lg rounded-pill" })
                    }
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-boxes text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="h5 fw-bold">Gestión del Inventario</h3>
                    <p class="text-muted">
                        Administre y controle el inventario de los productos disponibles, así como su nivel de stock.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-ticket text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="h5 fw-bold">Reservas</h3>
                    <p class="text-muted">
                        Crea y gestiona las diferentes reservas de los clientes para mantener un control.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-graph-up text-warning" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="h5 fw-bold">Reportes Mensuales</h3>
                    <p class="text-muted">
                        Genere y consulte reportes detallados de las transacciones y comisiones generadas.
                    </p>
                </div>
            </div>
        </div>
    </div>

    @if (Request.IsAuthenticated)
    {
        <section class="card p-4 mt-4">
            <div class="card-body">
                <h3 class="h4 fw-bold mb-4">
                    <i class="bi bi-grid-3x3-gap-fill me-2"></i>
                    Módulos Disponibles
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Punto de Venta
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Gestión de Órdenes
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Inventario en Tiempo Real
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Usuarios y Roles
                            </li>
                        </ul>
                    </div>

                    <div class="col-md-6">
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Contabilidad y Cierre de Caja
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Promociones Automáticas
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Reservaciones
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Reportes y Marketing
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    }
</div>
