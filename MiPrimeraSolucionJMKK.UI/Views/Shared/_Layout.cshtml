<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Gestión PubRock</title>

    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/site.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background-color: var(--secundario);
            font-family: 'Open Sans', sans-serif;
            color: var(--terciario);
        }

        :root {
            --primario: #3E2723;
            --secundario: #121212;
            --terciario: #F5E0C3;
            --acento: #EA9999;
            --exito: #82E0AA;
            --alerta: #F8C471;
        }

        .sidebar {
            min-height: 100vh;
            width: 280px;
            background-color: var(--primario);
            color: var(--terciario);
            border-right: 1px solid rgba(234,153,153,0.2);
        }

            .sidebar .nav-link {
                color: var(--terciario);
                text-decoration: none;
                padding: 12px 15px;
                margin: 5px 0;
                border-radius: 8px;
                font-weight: 600;
                transition: all 0.3s ease;
            }

                .sidebar .nav-link:hover {
                    background-color: var(--acento);
                    color: var(--secundario);
                    padding-left: 20px;
                }

                .sidebar .nav-link.active {
                    background-color: rgba(234,153,153,0.2);
                    border-left: 4px solid var(--acento);
                }

        .content {
            padding: 2rem;
            background-color: var(--secundario);
            color: var(--terciario);
        }

        footer {
            background-color: var(--primario);
            border-top: 2px solid var(--acento);
            color: var(--terciario);
            padding: 1rem;
            text-align: center;
        }

        .logo-text {
            font-family: 'Oswald', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--acento);
            text-transform: uppercase;
            text-align: center;
            padding: 20px 0;
            border-bottom: 2px solid rgba(234,153,153,0.3);
            margin-bottom: 20px;
        }

        .nav-section-title {
            color: var(--acento);
            font-family: 'Oswald', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.8rem;
            padding: 15px 15px 5px;
        }

        .card {
            background: linear-gradient(145deg,#3E2723,#2b1b18);
            border: none;
            border-radius: 15px;
            color: var(--terciario);
            box-shadow: 0 4px 15px rgba(0,0,0,.3);
            transition: all .3s ease;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 25px rgba(234,153,153,.2);
            }

        h2 {
            font-family: 'Oswald', sans-serif;
            color: var(--acento);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .form-label {
            color: var(--terciario);
            font-weight: 600;
        }

        .form-control {
            background-color: #1b1b1b;
            color: var(--terciario);
            border: 1px solid rgba(245,224,195,.15);
        }

            .form-control:focus {
                background-color: #1b1b1b;
                color: var(--terciario);
                border-color: var(--acento);
                box-shadow: 0 0 10px rgba(234,153,153,.25);
            }

        .btn-pubrock {
            background-color: var(--acento);
            color: var(--secundario);
            border: none;
            font-weight: 700;
            transition: .3s ease;
        }

            .btn-pubrock:hover {
                background-color: var(--terciario);
                color: var(--secundario);
                transform: translateY(-2px);
            }

        .link-acento {
            color: var(--acento);
        }

            .link-acento:hover {
                color: var(--terciario);
            }

        .login-card {
            width: 420px;
            margin: auto;
        }

        .card h1,
        .card h2,
        .card h3,
        .card h4,
        .card h5,
        .card h6 {
            color: var(--terciario) !important;
        }

        .card p,
        .card span,
        .card small {
            color: var(--terciario) !important;
            opacity: 0.9;
        }

        .text-muted {
            color: rgba(245,224,195,0.75) !important;
        }

    </style>
</head>
<body>

    <div class="d-flex">

        <div class="sidebar p-3 flex-shrink-0" style="width: 280px;">
            <div class="logo-text">
                <i class="bi bi-cash-coin"></i> Gestión PubRock
            </div>

            <ul class="nav flex-column">

                @if (User.Identity.IsAuthenticated)
                {
                    if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-section-title">Navegación</li>
                        <li class="nav-item">
                            @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-section-title">Gestión</li>
                        <li class="nav-item">
                            @Html.ActionLink("Comercios", "ObtenerTodosLosComercios", "Comercios", null, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Usuarios", "ObtenerTodosLosUsuarios", "Usuarios", null, new { @class = "nav-link" })
                        </li>


                        <li class="nav-section-title">Operaciones</li>
                        <li class="nav-item">
                            @Html.ActionLink("Registrar SINPE", "RegistrarSINPES", "SINPES", null, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Reportes Mensuales", "ObtenerTodosLosReportesMensuales", "ReportesMensuales", null, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Bitácora", "Index", "Bitacora", null, new { @class = "nav-link" })
                        </li>
                    }

                    if (User.IsInRole("Empleado"))
                    {
                        <li class="nav-section-title">Navegación</li>
                        <li class="nav-item">
                            @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Mis Cajas", "ObtenerTodasLasCajas", "Cajas", null, new { @class = "nav-link" })
                        </li>
                    }
                }
                else
                {
                    <li class="nav-item">
                        @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })
                    </li>
                }
            </ul>

            <div class="mt-auto pt-4" style="border-top: 2px solid rgba(255,255,255,0.2);">
                @Html.Partial("_LoginPartial")
            </div>
        </div>
        <div class="content flex-grow-1">
            @RenderBody()
        </div>

    </div>

    <!-- FOOTER -->
    <footer>
        © @DateTime.Now.Year - Sistema Gestión de PubRock
    </footer>

    <script src="~/Scripts/jquery-3.7.0.js"></script>
    <script src="~/Scripts/bootstrap.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>