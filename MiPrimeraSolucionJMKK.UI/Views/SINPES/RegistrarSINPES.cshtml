@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.SINPES.SINPESDto

@{
    ViewBag.Title = "Registrar SINPES";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-white text-center py-3 rounded-top-4">
                    <h3 class="mb-0"><i class="bi bi-send-check"></i> Registrar SINPE</h3>
                </div>

                <div class="card-body p-4">
                    @* Mensaje de éxito *@
                    @if (TempData["Exito"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Exito"]
                            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    }

                    @* Mensaje de error *@
                    @if (TempData["MensajeError"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["MensajeError"]
                            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    }

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        <div class="mb-3">
                            @Html.LabelFor(model => model.TelefonoOrigen, "Teléfono Origen", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.TelefonoOrigen, new { htmlAttributes = new { @class = "form-control", placeholder = "Ej: 88881234" } })
                            @Html.ValidationMessageFor(model => model.TelefonoOrigen, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.NombreOrigen, "Nombre Origen", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.NombreOrigen, new { htmlAttributes = new { @class = "form-control", placeholder = "Nombre completo" } })
                            @Html.ValidationMessageFor(model => model.NombreOrigen, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.TelefonoDestinatario, "Teléfono Destinatario", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.TelefonoDestinatario, new { htmlAttributes = new { @class = "form-control", placeholder = "Ej: 88881234" } })
                            @Html.ValidationMessageFor(model => model.TelefonoDestinatario, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.NombreDestinatario, "Nombre Destinatario", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.NombreDestinatario, new { htmlAttributes = new { @class = "form-control", placeholder = "Nombre completo" } })
                            @Html.ValidationMessageFor(model => model.NombreDestinatario, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.Monto, "Monto", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.Monto, new { htmlAttributes = new { @class = "form-control", placeholder = "Ej: 5000" } })
                            @Html.ValidationMessageFor(model => model.Monto, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.Descripcion, "Descripción", new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.Descripcion, new { htmlAttributes = new { @class = "form-control", placeholder = "Opcional: breve descripción" } })
                            @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger small" })
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <input type="submit" value="Crear SINPE" class="btn btn-success btn-lg rounded-pill shadow-sm" />
                            @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary btn-lg rounded-pill shadow-sm" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}