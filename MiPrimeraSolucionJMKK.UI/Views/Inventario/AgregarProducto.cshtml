@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.Productos.ProductoDto

@{
    ViewBag.Title = "Agregar Producto";
}

<h2>Registrar Producto</h2>

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger">@TempData["MensajeError"]</div>
}

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success">@TempData["MensajeExito"]</div>
}

@using (Html.BeginForm("AgregarProducto", "Inventario", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @Html.ValidationSummary(true, "Por favor corrija los errores del formulario", new { @class = "text-danger" })

    @* Codigo se genera automatico en el servidor *@

    <div class="mb-3">
        @Html.LabelFor(m => m.Nombre)
        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Categoria)
        @Html.DropDownListFor(m => m.Categoria, ViewBag.Categorias as System.Web.Mvc.SelectList, "-- Seleccione --", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Categoria, "", new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Cantidad)
        @Html.TextBoxFor(m => m.Cantidad, new { @class = "form-control", type = "number", step = "1" })
        @Html.ValidationMessageFor(m => m.Cantidad, "", new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.PrecioUnitario)
        @Html.TextBoxFor(m => m.PrecioUnitario, new { @class = "form-control", type = "number", step = "0.01" })
        @Html.ValidationMessageFor(m => m.PrecioUnitario, "", new { @class = "text-danger" })
    </div>

    <button class="btn btn-primary" type="submit">Guardar Producto</button>
}
