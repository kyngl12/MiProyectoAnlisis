@model MiPrimeraSolucionJMKK.Abstracciones.Modelos.Ordenes.OrdenDto

@{
    ViewBag.Title = "Crear Orden";
}

<h2>Crear Orden de Compra</h2>

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger">@TempData["MensajeError"]</div>
}

@using (Html.BeginForm("Crear", "Ordenes", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @* NumeroOrden se genera/ignora en BD (autoincremental) *@

    <div class="mb-3">
        @Html.LabelFor(m => m.IdProducto, "Producto")
        @Html.DropDownListFor(m => m.IdProducto, ViewBag.Productos as System.Web.Mvc.SelectList, "-- Seleccione --", new { @class = "form-control" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Cantidad)
        @Html.TextBoxFor(m => m.Cantidad, new { @class = "form-control", type = "number", step = "1" })
        @Html.ValidationMessageFor(m => m.Cantidad, "", new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.IdProveedor, "Proveedor")
        @Html.DropDownListFor(m => m.IdProveedor, ViewBag.Proveedores as System.Collections.Generic.List<System.Web.Mvc.SelectListItem>, "-- Seleccione --", new { @class = "form-control" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.FechaEntregaEstim, "Fecha Entrega Estimada")
        @Html.TextBoxFor(m => m.FechaEntregaEstim, new { @class = "form-control", type = "date" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Observaciones, "Observaciones")
        @Html.TextAreaFor(m => m.Observaciones, new { @class = "form-control", rows = 3 })
    </div>

    <button class="btn btn-primary" type="submit">Crear Orden</button>
}
